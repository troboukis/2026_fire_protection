# Supabase credentials
# Get these from: https://supabase.com/dashboard/project/_/settings/api
# New key format (2025): sb_publishable_... and sb_secret_...
# Legacy format: eyJ... (also works — see "Legacy anon, service_role API keys" tab)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_...   # Secret key (server-side ingest only)
SUPABASE_ANON_KEY=sb_publishable_... # Publishable key (used by the React app)

# Postgres direct connection (for schema application via psql)
# Get from: Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres
